---
const pages = [
  { url: '/', priority: '1.0', changefreq: 'monthly' },
  { url: '/services', priority: '0.9', changefreq: 'monthly' },
  { url: '/work', priority: '0.8', changefreq: 'monthly' },
  { url: '/work/thefacelab', priority: '0.7', changefreq: 'monthly' },
  { url: '/about', priority: '0.8', changefreq: 'monthly' },
  { url: '/contact', priority: '0.8', changefreq: 'yearly' },
  { url: '/calculator', priority: '0.6', changefreq: 'yearly' },
];
const base = 'https://brandonburton.co.uk';
const today = new Date().toISOString().split('T')[0];
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {pages.map(p => (
    <url>
      <loc>{base}{p.url}</loc>
      <lastmod>{today}</lastmod>
      <changefreq>{p.changefreq}</changefreq>
      <priority>{p.priority}</priority>
    </url>
  ))}
</urlset>
