---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  { title: 'Web Design & Build', desc: 'A site that looks the part and actually converts. Built clean, fast, and fully yours.', from: 'From £1,200', color: '#1a1a1a' },
  { title: 'Digital Setup', desc: 'Google Business, email, analytics, booking tools — everything configured and connected.', from: 'From £350', color: '#1e2a4a' },
  { title: 'Ongoing Care', desc: 'Monthly support so your site stays sharp, secure, and up to date. No more chasing freelancers.', from: 'From £120/mo', color: '#1a2e1e' },
  { title: 'Strategy Session', desc: 'A focused 60-minute call to cut through the noise and figure out your best next step.', from: '£150 flat', color: '#2a1f14' },
];
---

<BaseLayout>
  <Nav />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <p class="hero-eyebrow reveal-item">Web Design & Digital Strategy · Oxfordshire</p>
          <h1 class="hero-headline reveal-item" style="transition-delay: 0.1s">
            Your business deserves<br />
            a website <em>that actually works.</em>
          </h1>
          <p class="hero-sub reveal-item" style="transition-delay: 0.2s">
            I'm Brandon Burton — I design and build clean, fast websites for small businesses,
            and stick around to make sure they stay that way.
          </p>
          <div class="hero-actions reveal-item" style="transition-delay: 0.3s">
            <a href="/contact" class="btn-primary">Start a project</a>
            <a href="/work" class="btn-ghost">See my work →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- MARQUEE STRIP -->
    <div class="marquee-wrap">
      <div class="marquee-track" aria-hidden="true">
        <span>Web Design</span><span class="dot">·</span>
        <span>Digital Strategy</span><span class="dot">·</span>
        <span>Ongoing Care</span><span class="dot">·</span>
        <span>Small Business</span><span class="dot">·</span>
        <span>Oxfordshire</span><span class="dot">·</span>
        <span>Fast & Clean</span><span class="dot">·</span>
        <span>Web Design</span><span class="dot">·</span>
        <span>Digital Strategy</span><span class="dot">·</span>
        <span>Ongoing Care</span><span class="dot">·</span>
        <span>Small Business</span><span class="dot">·</span>
        <span>Oxfordshire</span><span class="dot">·</span>
        <span>Fast & Clean</span><span class="dot">·</span>
      </div>
    </div>

    <!-- SERVICES PREVIEW -->
    <section class="services-section">
      <div class="container">
        <div class="section-header reveal-item">
          <h2 class="section-title">What I do</h2>
          <a href="/services" class="section-link">View all services →</a>
        </div>
        <div class="services-grid">
          {services.map((s, i) => (
            <div class="service-card reveal-item" style={`--hover-bg: ${s.color}; transition-delay: ${i * 0.08}s`}>
              <div class="card-inner">
                <h3 class="card-title">{s.title}</h3>
                <p class="card-desc">{s.desc}</p>
                <span class="card-from">{s.from}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BUILT FOR -->
    <section class="built-for reveal-item">
      <div class="container">
        <p class="built-label">Built for</p>
        <div class="built-pills">
          <span class="pill">Local businesses</span>
          <span class="pill">Beauty & hospitality</span>
          <span class="pill">Personal brands</span>
          <span class="pill">New ventures</span>
          <span class="pill">Trades & services</span>
          <span class="pill">Clinics & studios</span>
        </div>
      </div>
    </section>

    <!-- WORK PREVIEW -->
    <section class="work-preview">
      <div class="container">
        <div class="section-header reveal-item">
          <h2 class="section-title">Recent work</h2>
          <a href="/work" class="section-link">All projects →</a>
        </div>
        <div class="case-card reveal-item">
          <div class="case-info">
            <span class="case-tag">Case study</span>
            <h3 class="case-title">TheFaceLab</h3>
            <p class="case-desc">Two-salon beauty brand in Oxfordshire. Full digital setup, website build, and ongoing monthly care to keep them growing online.</p>
            <a href="/work/thefacelab" class="btn-ghost">Read case study →</a>
          </div>
          <div class="case-visual">
            <div class="case-placeholder">TFL</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA STRIP -->
    <section class="cta-strip">
      <div class="container">
        <div class="cta-inner reveal-item">
          <div class="cta-text">
            <h2 class="cta-title">Ready to get started?</h2>
            <p class="cta-sub">No pressure, no jargon. Just a conversation about what your business needs.</p>
          </div>
          <a href="/contact" class="btn-cta-large">Book a free call</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── REVEAL ANIMATIONS ── */
  .reveal-item { opacity: 0; transform: translateY(28px); transition: opacity 0.7s cubic-bezier(0.25, 1, 0.5, 1), transform 0.7s cubic-bezier(0.25, 1, 0.5, 1); }
  .reveal-item.revealed { opacity: 1; transform: none; }

  /* ── HERO ── */
  .hero { padding: calc(68px + 7rem) 0 6rem; }
  .hero-inner { max-width: 780px; }
  .hero-eyebrow { font-size: 0.78rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid); margin-bottom: 1.75rem; }
  .hero-headline { font-size: clamp(3rem, 6vw, 5rem); font-weight: 700; line-height: 1.06; letter-spacing: -0.035em; color: var(--ink); margin-bottom: 1.75rem; }
  .hero-headline em { font-style: normal; color: var(--mid); }
  .hero-sub { font-size: 1.1rem; line-height: 1.75; color: var(--mid); max-width: 540px; margin-bottom: 2.75rem; font-weight: 400; }
  .hero-actions { display: flex; gap: 1.25rem; flex-wrap: wrap; align-items: center; }

  /* ── BUTTONS ── */
  .btn-primary { font-size: 0.9rem; font-weight: 600; background: var(--ink); color: var(--bg); padding: 0.8rem 1.75rem; border-radius: 100px; transition: opacity 0.2s, transform 0.2s; display: inline-block; }
  .btn-primary:hover { opacity: 0.75; transform: translateY(-1px); }
  .btn-ghost { font-size: 0.9rem; font-weight: 500; color: var(--mid); transition: color 0.2s; }
  .btn-ghost:hover { color: var(--ink); }

  /* ── MARQUEE ── */
  .marquee-wrap { overflow: hidden; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); padding: 0.9rem 0; white-space: nowrap; background: var(--surface); }
  .marquee-track { display: inline-block; animation: marqueeScroll 28s linear infinite; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mid); }
  .marquee-track span { padding: 0 0.5rem; }
  .marquee-track .dot { color: var(--soft); }
  @keyframes marqueeScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ── SECTION SHARED ── */
  .services-section, .built-for, .work-preview, .cta-strip { padding: var(--section-gap) 0 0; }
  .section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2rem; border-bottom: 1px solid var(--rule); padding-bottom: 1rem; }
  .section-title { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid); }
  .section-link { font-size: 0.85rem; color: var(--mid); transition: color 0.2s; }
  .section-link:hover { color: var(--ink); }

  /* ── SERVICES GRID ── */
  .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .service-card { background: var(--surface); border: 1px solid var(--rule); border-radius: var(--radius); padding: 2rem; transition: background 0.3s ease, border-color 0.3s, color 0.3s, transform 0.25s ease, box-shadow 0.25s ease; cursor: default; }
  .service-card:hover { background: var(--hover-bg); border-color: transparent; color: #fff; transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.14); }
  .service-card:hover .card-desc, .service-card:hover .card-from { color: rgba(255,255,255,0.6); }
  .card-title { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.6rem; color: var(--ink); transition: color 0.3s; }
  .service-card:hover .card-title { color: #fff; }
  .card-desc { font-size: 0.875rem; color: var(--mid); line-height: 1.65; margin-bottom: 1.5rem; transition: color 0.3s; }
  .card-from { font-size: 0.8rem; font-weight: 600; color: var(--soft); letter-spacing: 0.02em; transition: color 0.3s; }

  /* ── BUILT FOR ── */
  .built-for .container { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .built-label { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid); flex-shrink: 0; }
  .built-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pill { font-size: 0.82rem; font-weight: 500; color: var(--mid); border: 1px solid var(--rule); border-radius: 100px; padding: 0.4rem 1rem; background: var(--surface); transition: border-color 0.2s, color 0.2s, background 0.2s; }
  .pill:hover { border-color: var(--ink); color: var(--ink); background: var(--surface2); }

  /* ── WORK PREVIEW ── */
  .case-card { background: var(--surface); border: 1px solid var(--rule); border-radius: var(--radius); padding: 3rem; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; transition: box-shadow 0.3s; }
  .case-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); }
  .case-tag { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid); display: block; margin-bottom: 0.75rem; }
  .case-title { font-size: 2rem; font-weight: 700; letter-spacing: -0.025em; margin-bottom: 1rem; color: var(--ink); }
  .case-desc { font-size: 0.9rem; color: var(--mid); line-height: 1.7; margin-bottom: 1.5rem; }
  .case-visual { background: var(--surface2); border-radius: var(--radius-sm); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; }
  .case-placeholder { font-size: 2rem; font-weight: 700; color: var(--rule); letter-spacing: 0.05em; }

  /* ── CTA STRIP ── */
  .cta-strip { padding-bottom: var(--section-gap); }
  .cta-inner { background: var(--ink); color: var(--bg); border-radius: var(--radius); padding: 4rem 3.5rem; display: flex; align-items: center; justify-content: space-between; gap: 3rem; }
  .cta-text { max-width: 480px; }
  .cta-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.025em; margin-bottom: 0.6rem; line-height: 1.15; }
  .cta-sub { font-size: 0.95rem; opacity: 0.55; line-height: 1.6; }
  .btn-cta-large { font-size: 0.9rem; font-weight: 600; background: var(--bg); color: var(--ink); padding: 0.85rem 2rem; border-radius: 100px; white-space: nowrap; transition: opacity 0.2s, transform 0.2s; flex-shrink: 0; display: inline-block; }
  .btn-cta-large:hover { opacity: 0.85; transform: translateY(-1px); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
    .case-card { grid-template-columns: 1fr; padding: 2rem; }
    .case-visual { display: none; }
    .cta-inner { flex-direction: column; align-items: flex-start; padding: 2.5rem 1.75rem; }
    .built-for .container { gap: 1rem; }
  }
</style>

<script is:inline>
  // ── SCROLL REVEAL ──
  const reveals = document.querySelectorAll('.reveal-item');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('revealed'); observer.unobserve(e.target); }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  reveals.forEach(el => observer.observe(el));


</script>
