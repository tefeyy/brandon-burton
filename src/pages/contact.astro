---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact — Brandon Burton">
  <Nav />

  <!-- Hidden form for Netlify build-time detection (required) -->
  <form name="contact" netlify netlify-honeypot="bot-field" hidden>
    <input type="text" name="name" />
    <input type="email" name="email" />
    <input type="text" name="business" />
    <textarea name="message"></textarea>
  </form>

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">Contact</p>
        <h1 class="page-title">Let's talk</h1>
        <p class="page-sub">Choose whichever works best for you — fill in the form and I'll get back to you within one working day, or book a free 30-minute call directly in my calendar.</p>
      </div>
    </section>

    <section class="contact-body">
      <div class="container">

        <!-- Two column option selector -->
        <div class="contact-options">
          <button class="option-tab active" data-tab="form">
            <span class="option-icon">✉️</span>
            <span class="option-label">Send a message</span>
            <span class="option-desc">I'll reply within one working day</span>
          </button>
          <button class="option-tab" data-tab="calendar">
            <span class="option-icon">📅</span>
            <span class="option-label">Book a free call</span>
            <span class="option-desc">Pick a time that suits you</span>
          </button>
        </div>

        <!-- FORM PANEL -->
        <div class="contact-panel active" id="panel-form">
          <div class="contact-grid">
            <div class="contact-form-wrap">
              <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" class="contact-form">
                <input type="hidden" name="form-name" value="contact" />
                <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
                <div class="field">
                  <label for="name">Your name</label>
                  <input type="text" id="name" name="name" placeholder="Jane Smith" required />
                </div>
                <div class="field">
                  <label for="email">Email address</label>
                  <input type="email" id="email" name="email" placeholder="jane@example.com" required />
                </div>
                <div class="field">
                  <label for="business">Business name (optional)</label>
                  <input type="text" id="business" name="business" placeholder="My Business Ltd" />
                </div>
                <div class="field">
                  <label for="message">What are you working on?</label>
                  <textarea id="message" name="message" rows="5" placeholder="Tell me about your project, what you need, and any timeline..." required></textarea>
                </div>
                <button type="submit" class="btn-submit">Send message →</button>
              </form>
            </div>
            <div class="contact-info">
              <div class="info-card">
                <h3>Email</h3>
                <a href="mailto:hello@brandonburton.co.uk">hello@brandonburton.co.uk</a>
              </div>
              <div class="info-card">
                <h3>Based in</h3>
                <p>Witney, Oxfordshire<br />Available for local & UK-wide projects</p>
              </div>
              <div class="info-card">
                <h3>Prefer to call?</h3>
                <p>Switch to the "Book a free call" tab above to pick a time directly in my calendar.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- CALENDLY PANEL -->
        <div class="contact-panel" id="panel-calendar">
          <div class="calendly-wrap">
            <div class="calendly-inline-widget" data-url="https://calendly.com/brandon-brandonburton/30min?hide_gdpr_banner=1&primary_color=1a1a1a"></div>
          </div>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<!-- Calendly script -->
<script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>

<!-- Tab switching -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.option-tab');
    const panels = document.querySelectorAll('.contact-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach(t => t.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('panel-' + target)?.classList.add('active');
      });
    });
  });
</script>

<style>
  .hidden { display: none; }
  .page-hero {
    padding: calc(68px + 5rem) 0 4rem;
    border-bottom: 1px solid var(--rule);
  }
  .eyebrow { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid); margin-bottom: 1rem; }
  .page-title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 0.75rem; color: var(--ink); }
  .page-sub { font-size: 1rem; color: var(--mid); line-height: 1.7; max-width: 580px; }
  .contact-body { padding: var(--section-gap) 0 0; }
  .contact-options { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 3rem; max-width: 640px; }
  .option-tab { display: flex; flex-direction: column; align-items: flex-start; gap: 0.3rem; padding: 1.25rem 1.5rem; background: var(--surface); border: 1.5px solid var(--rule); border-radius: var(--radius); cursor: pointer; transition: border-color 0.2s, background 0.2s; text-align: left; }
  .option-tab:hover { border-color: var(--mid); }
  .option-tab.active { border-color: var(--ink); background: var(--surface2); }
  .option-icon { font-size: 1.25rem; margin-bottom: 0.25rem; }
  .option-label { font-size: 0.9rem; font-weight: 600; color: var(--ink); }
  .option-desc { font-size: 0.78rem; color: var(--mid); }
  .contact-panel { display: none; }
  .contact-panel.active { display: block; }
  .contact-grid { display: grid; grid-template-columns: 1fr 320px; gap: 5rem; align-items: start; }
  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  label { font-size: 0.8rem; font-weight: 600; color: var(--ink); letter-spacing: 0.02em; }
  input, textarea { font-family: var(--font); font-size: 0.9rem; color: var(--ink); background: var(--surface); border: 1.5px solid var(--rule); border-radius: var(--radius-sm); padding: 0.7rem 0.9rem; transition: border-color 0.2s; resize: vertical; outline: none; }
  input::placeholder, textarea::placeholder { color: var(--soft); }
  input:focus, textarea:focus { border-color: var(--ink); }
  .btn-submit { font-size: 0.9rem; font-weight: 600; background: var(--ink); color: var(--bg); padding: 0.8rem 1.6rem; border-radius: 100px; align-self: flex-start; transition: opacity 0.2s; cursor: pointer; font-family: var(--font); border: none; }
  .btn-submit:hover { opacity: 0.75; }
  .info-card { padding: 1.25rem; border: 1px solid var(--rule); border-radius: var(--radius-sm); margin-bottom: 0.75rem; }
  .info-card h3 { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--soft); margin-bottom: 0.4rem; }
  .info-card a { font-size: 0.875rem; color: var(--ink); text-decoration: underline; text-underline-offset: 3px; }
  .info-card p { font-size: 0.875rem; color: var(--mid); line-height: 1.6; }
  .calendly-wrap { border: 1px solid var(--rule); border-radius: var(--radius); overflow: hidden; }
  .calendly-inline-widget { min-width: 320px; height: 700px; }
  @media (max-width: 768px) {
    .contact-options { grid-template-columns: 1fr; max-width: 100%; }
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .calendly-inline-widget { height: 600px; }
  }
</style>
