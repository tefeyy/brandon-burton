---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Web Design & Build',
    desc: 'A professionally designed website built to reflect your brand and convert visitors into customers. Includes design, development, copywriting guidance, and launch.',
    from: 'From £1,200',
    range: '£1,200 – £3,500',
    details: ['Custom design to your brand', 'Mobile-first and fast', 'CMS if needed', 'SEO foundations', 'Launch support'],
  },
  {
    title: 'Digital Setup',
    desc: 'Everything you need to show up online: Google Business, email setup, analytics, booking tools, and social profiles — all configured and connected properly.',
    from: 'From £350',
    range: '£350 – £700',
    details: ['Google Business Profile', 'Email setup', 'Google Analytics', 'Booking tool integration', 'Social profile review'],
  },
  {
    title: 'Ongoing Care',
    desc: 'Monthly support so your site stays sharp, secure, and current. Pick the plan that fits — and never think about updates again.',
    from: 'From £120/mo',
    range: 'See plans below',
    details: ['Essentials: £120/mo', 'Standard: £200/mo', 'Growth: £350/mo'],
  },
  {
    title: 'Strategy Session',
    desc: "A focused 60-minute conversation to work through your digital presence, identify what's holding you back, and map out your best next step.",
    from: '£150 flat',
    range: 'Credited to any project',
    details: ['60 minutes', 'Recorded and shared', 'Action summary', 'Credit toward any project'],
  },
];
---

<BaseLayout title="Services — Brandon Burton">
  <Nav />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">Services</p>
        <h1 class="page-title">What I can do for you</h1>
        <p class="page-sub">From a brand new website to a monthly retainer — everything a small business needs to look great and grow online.</p>
      </div>
    </section>

    <section class="services-list">
      <div class="container">
        {services.map((s, i) => (
          <div class={`service-row ${i % 2 === 1 ? 'reverse' : ''}`}>
            <div class="service-info">
              <h2 class="service-name">{s.title}</h2>
              <p class="service-desc">{s.desc}</p>
              <div class="service-pricing">
                <span class="price-from">{s.from}</span>
                <span class="price-range">{s.range}</span>
              </div>
              <a href="/contact" class="btn-outline">Enquire →</a>
            </div>
            <div class="service-details">
              <ul>
                {s.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding: calc(68px + 5rem) 0 4rem;
    border-bottom: 1px solid var(--rule);
  }
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mid);
    margin-bottom: 1rem;
  }
  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    color: var(--ink);
  }
  .page-sub {
    font-size: 1rem;
    color: var(--mid);
    max-width: 560px;
    line-height: 1.7;
  }
  .services-list { padding: var(--section-gap) 0 0; }
  .service-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }
  .service-row.reverse { direction: rtl; }
  .service-row.reverse > * { direction: ltr; }
  .service-name {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    color: var(--ink);
  }
  .service-desc {
    font-size: 0.9rem;
    color: var(--mid);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .service-pricing {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .price-from {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
  }
  .price-range {
    font-size: 0.8rem;
    color: var(--soft);
  }
  .btn-outline {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink);
    border: 1.5px solid var(--ink);
    padding: 0.55rem 1.2rem;
    border-radius: 100px;
    display: inline-block;
    transition: background 0.2s, color 0.2s;
  }
  .btn-outline:hover { background: var(--ink); color: var(--bg); }
  .service-details ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 0.5rem;
  }
  .service-details li {
    font-size: 0.875rem;
    color: var(--mid);
    padding-left: 1.25rem;
    position: relative;
  }
  .service-details li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--soft);
  }
  @media (max-width: 768px) {
    .service-row, .service-row.reverse {
      grid-template-columns: 1fr;
      direction: ltr;
      gap: 1.5rem;
    }
  }
</style>
