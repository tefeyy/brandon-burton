---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Message sent — Brandon Burton">
  <Nav />
  <main>
    <section class="thankyou">
      <div class="container">
        <div class="ty-inner">
          <span class="ty-icon">✓</span>
          <h1>Message received</h1>
          <p>Thanks for getting in touch. I'll get back to you within one working day.</p>
          <a href="/" class="btn-home">Back to home →</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .thankyou {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    padding: calc(68px + 4rem) 0;
  }
  .ty-inner {
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ty-icon {
    width: 48px;
    height: 48px;
    background: var(--ink);
    color: var(--bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  p { font-size: 0.95rem; color: var(--mid); line-height: 1.7; }
  .btn-home {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--mid);
    margin-top: 0.5rem;
    transition: color 0.2s;
    display: inline-block;
  }
  .btn-home:hover { color: var(--ink); }
</style>
