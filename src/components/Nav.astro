---
const navLinks = [
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="site-nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-bb">BB</span>
      <span class="logo-divider"></span>
      <span class="logo-name">Brandon Burton</span>
    </a>

    <nav class="nav-links">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link ${currentPath.startsWith(link.href) ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="nav-actions">
      <a href="/contact" class="btn-cta">Let's Talk</a>
      <button class="theme-toggle" aria-label="Toggle theme">
        <span class="toggle-icon">🌙</span>
      </button>
    </div>

    <button class="nav-burger" aria-label="Open menu" id="burgerBtn">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="nav-mobile" id="mobileMenu">
    {navLinks.map(link => (
      <a href={link.href} class="nav-mobile-link">{link.label}</a>
    ))}
    <a href="/contact" class="btn-cta mobile-cta">Let's Talk</a>
  </div>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  /* Shrinks slightly on scroll — feels more refined */
  .site-nav.scrolled {
    background: color-mix(in srgb, var(--bg) 96%, transparent);
    box-shadow: 0 1px 0 var(--rule), 0 6px 24px rgba(0,0,0,0.05);
  }
  .site-nav.scrolled .nav-inner {
    height: 58px;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    height: 68px;
    gap: 2rem;
    transition: height 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .logo-bb {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .logo-divider {
    width: 1px;
    height: 1.2rem;
    background: var(--rule);
  }
  .logo-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink);
    white-space: nowrap;
  }
  .nav-links {
    display: flex;
    gap: 0.25rem;
    margin-left: auto;
  }
  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--mid);
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--ink);
    background: var(--surface2);
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .btn-cta {
    font-size: 0.875rem;
    font-weight: 600;
    background: var(--ink);
    color: var(--bg);
    padding: 0.5rem 1.1rem;
    border-radius: 100px;
    transition: opacity 0.2s;
  }
  .btn-cta:hover { opacity: 0.8; }
  .theme-toggle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--surface2);
    border: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    transition: background 0.2s;
    cursor: pointer;
  }
  .theme-toggle:hover { background: var(--rule); }
  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    margin-left: auto;
    background: none;
    border: none;
    cursor: pointer;
  }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: background 0.2s;
  }
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 1.25rem 1.5rem;
    gap: 0.25rem;
    border-top: 1px solid var(--rule);
    background: var(--bg);
  }
  .nav-mobile.open { display: flex; }
  .nav-mobile-link {
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .mobile-cta {
    margin-top: 1rem;
    text-align: center;
    display: block;
  }

  @media (max-width: 768px) {
    .nav-links, .nav-actions { display: none; }
    .nav-burger { display: flex; }
  }
</style>

<script is:inline>
  document.getElementById('burgerBtn')?.addEventListener('click', () => {
    document.getElementById('mobileMenu')?.classList.toggle('open');
  });
</script>
