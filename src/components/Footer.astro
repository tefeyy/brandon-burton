<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="footer-logo">BB</span>
      <span class="footer-name">Brandon Burton</span>
    </div>
    <nav class="footer-links">
      <a href="/services">Services</a>
      <a href="/work">Work</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>
    <p class="footer-copy">© {new Date().getFullYear()} Brandon Burton. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    padding: 2.5rem 0;
    margin-top: var(--section-gap);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .footer-logo {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink);
  }
  .footer-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--mid);
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    margin-left: auto;
  }
  .footer-links a {
    font-size: 0.85rem;
    color: var(--mid);
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--ink); }
  .footer-copy {
    font-size: 0.8rem;
    color: var(--soft);
    width: 100%;
  }

  @media (max-width: 640px) {
    .footer-links { margin-left: 0; flex-wrap: wrap; gap: 1rem; }
  }
</style>
